<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/categoryHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="14dp"
    android:paddingBottom="6dp"
    android:paddingStart="8dp"
    android:paddingEnd="4dp">

    <!-- Expand/Collapse tap area -->
    <LinearLayout
        android:id="@+id/expandCollapseArea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <ImageView
            android:id="@+id/ivExpandCollapse"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/arrow_down_float"
            android:tint="@color/neon_cyan"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvCategoryName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Category"
            android:textSize="13sp"
            android:textColor="@color/neon_cyan"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/tvCategoryCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textSize="11sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="sans-serif"
            android:layout_marginEnd="8dp" />

    </LinearLayout>

    <!-- Move Up -->
    <ImageButton
        android:id="@+id/btnMoveUp"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/arrow_up_float"
        android:tint="@color/text_tertiary"
        android:scaleType="centerInside"
        android:contentDescription="Move up" />

    <!-- Move Down -->
    <ImageButton
        android:id="@+id/btnMoveDown"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/arrow_down_float"
        android:tint="@color/text_tertiary"
        android:scaleType="centerInside"
        android:contentDescription="Move down" />

    <!-- Long-press menu (default collapse) -->
    <ImageButton
        android:id="@+id/btnCategoryMenu"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_more"
        android:tint="@color/text_tertiary"
        android:scaleType="centerInside"
        android:contentDescription="Category options" />

</LinearLayout>
