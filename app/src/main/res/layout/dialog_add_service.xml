<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Service"
        android:textSize="24sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp" />

    <!-- Service Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_cyan"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etServiceName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/service_name_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Service Type Toggle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerServiceType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface_dark"
        android:popupBackground="@color/surface_elevated"
        android:layout_marginBottom="16dp"
        android:padding="8dp" />

    <!-- Service URL Input (for web services) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/urlInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_cyan"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etServiceUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/service_url_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="textUri"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Public URL Input (optional fallback) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/publicUrlInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_orange"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPublicUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Public URL (optional, e.g. https://myservice.duckdns.org)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="textUri"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- App Picker Button (for app services) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickApp"
        style="@style/Button.Premium.Outlined"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Select App..."
        android:textSize="14sp"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Username Input (optional) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/usernameInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_cyan"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username (optional)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Password Input (optional) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_cyan"
        app:hintTextColor="@color/text_secondary"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (optional)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="textPassword"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Category Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/categoryInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:boxBackgroundColor="@color/surface_dark"
        app:boxBackgroundMode="filled"
        app:boxStrokeColor="@color/neon_cyan"
        app:hintTextColor="@color/text_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Category (e.g. Infrastructure, Media)"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:inputType="text"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Favorite Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Favorite"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Icon Source Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Icon"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerIcon"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface_dark"
        android:popupBackground="@color/surface_elevated"
        android:layout_marginBottom="8dp"
        android:padding="8dp" />

    <!-- Upload Custom Icon -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUploadIcon"
        style="@style/Button.Premium.Outlined"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Upload Custom Icon..."
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- View Mode Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="View Mode"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <Spinner
        android:id="@+id/spinnerViewMode"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface_dark"
        android:popupBackground="@color/surface_elevated"
        android:layout_marginBottom="16dp"
        android:padding="8dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Button.VPN.Premium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/save" />

    </LinearLayout>

</LinearLayout>

</ScrollView>
