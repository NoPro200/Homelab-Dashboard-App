<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/serviceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/glass_ultra_light"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <!-- Service Icon with Glow Effect -->
            <androidx.cardview.widget.CardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardBackgroundColor="@color/surface_elevated"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/ivServiceIcon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_proxmox"
                    android:scaleType="centerInside" />

            </androidx.cardview.widget.CardView>

            <!-- Service Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:id="@+id/tvServiceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Proxmox"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvServiceUrl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="https://proxmox.local:8006"
                    android:textSize="12sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="sans-serif"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginTop="4dp" />

                <!-- Tags Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <!-- VPN Required Badge -->
                    <TextView
                        android:id="@+id/tvVpnBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VPN"
                        android:textSize="10sp"
                        android:textColor="@color/neon_cyan"
                        android:background="@drawable/badge_vpn"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone" />

                    <!-- Has Credentials Badge -->
                    <TextView
                        android:id="@+id/tvCredentialsBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐 Saved"
                        android:textSize="10sp"
                        android:textColor="@color/neon_green"
                        android:background="@drawable/badge_credentials"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- More Button -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_more"
                android:tint="@color/text_secondary"
                android:scaleType="centerInside" />

        </LinearLayout>

        <!-- Optional: Quick Actions Bar -->
        <LinearLayout
            android:id="@+id/quickActionsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuickOpen"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Open"
                android:textColor="@color/neon_cyan"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuickEdit"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
