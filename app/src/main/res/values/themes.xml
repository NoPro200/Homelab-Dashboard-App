<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Theme -->
    <style name="Theme.HomelabDashboard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/neon_cyan</item>
        <item name="colorPrimaryVariant">@color/neon_purple</item>
        <item name="colorOnPrimary">@color/primary_dark</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/neon_pink</item>
        <item name="colorSecondaryVariant">@color/neon_orange</item>
        <item name="colorOnSecondary">@color/primary_dark</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/primary_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/primary_dark</item>
        
        <!-- Window Properties -->
        <item name="android:windowBackground">@color/primary_dark</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowEnterTransition">@android:transition/fade</item>
        <item name="android:windowExitTransition">@android:transition/fade</item>
    </style>
    
    <!-- Splash Screen Theme -->
    <style name="Theme.HomelabDashboard.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">500</item>
        <item name="postSplashScreenTheme">@style/Theme.HomelabDashboard</item>
    </style>
    
    <!-- Premium Button Styles -->
    <style name="Button.VPN.Premium" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/neon_cyan</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="iconTint">@color/primary_dark</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    
    <style name="Button.Premium.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/glass_light</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/glass_light</item>
    </style>
    
    <!-- Premium Card Style -->
    <style name="CardView.Premium" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_ultra_light</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
        <item name="contentPadding">20dp</item>
    </style>
    
    <!-- Premium TextInputLayout -->
    <style name="TextInputLayout.Premium" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/surface_elevated</item>
        <item name="boxBackgroundMode">filled</item>
        <item name="boxStrokeColor">@color/neon_cyan</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>
    
    <!-- Dialog Style -->
    <style name="Dialog.Premium" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background_premium</item>
        <item name="android:colorBackground">@color/secondary_dark</item>
        <item name="colorSurface">@color/surface_elevated</item>
    </style>
</resources>
